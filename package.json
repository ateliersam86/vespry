{
  "name": "vespry-discord-export",
  "private": true,
  "version": "0.1.0",
  "description": "Vespry — crash-proof, AI-ready Discord chat exporter (Chrome, Edge, Firefox).",
  "license": "MIT",
  "author": {
    "name": "Samuel Muselet",
    "url": "https://atelier-sam.fr"
  },
  "homepage": "https://github.com/ateliersam86/vespry#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ateliersam86/vespry.git"
  },
  "bugs": {
    "url": "https://github.com/ateliersam86/vespry/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:firefox": "vite --config vite.firefox.config.ts",
    "build": "tsc --noEmit && vite build",
    "build:firefox": "tsc --noEmit && vite build --config vite.firefox.config.ts",
    "build:all": "npm run build && npm run build:firefox",
    "firefox:run": "web-ext run --source-dir=dist-firefox --start-url=https://discord.com/channels/@me",
    "firefox:lint": "web-ext lint --source-dir=dist-firefox",
    "firefox:package": "web-ext build --source-dir=dist-firefox --artifacts-dir=web-ext-artifacts --overwrite-dest",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-test.mjs",
    "test:bridge": "node scripts/bridge-test.mjs",
    "test:e2e": "node scripts/e2e-test.mjs",
    "play": "node scripts/play.mjs"
  },
  "dependencies": {
    "@transcend-io/conflux": "^4.1.0",
    "@zip.js/zip.js": "^2.8.26",
    "idb": "^8.0.0",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@preact/preset-vite": "^2.10.1",
    "@types/chrome": "^0.0.287",
    "fake-indexeddb": "^6.0.0",
    "playwright": "^1.60.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.2",
    "web-ext": "^10.1.0"
  }
}
