{
  "name": "vespry-discord-export",
  "private": true,
  "version": "0.1.0",
  "description": "Vespry — crash-proof, AI-ready Discord chat exporter (Chrome extension).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-test.mjs",
    "test:bridge": "node scripts/bridge-test.mjs",
    "test:e2e": "node scripts/e2e-test.mjs",
    "play": "node scripts/play.mjs"
  },
  "dependencies": {
    "@transcend-io/conflux": "^4.1.0",
    "idb": "^8.0.0",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@preact/preset-vite": "^2.10.1",
    "@types/chrome": "^0.0.287",
    "fake-indexeddb": "^6.0.0",
    "playwright": "^1.60.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.2"
  }
}
